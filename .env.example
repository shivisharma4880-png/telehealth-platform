# =============================================================================
# AI Telehealth Platform – Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ---- Real integrations ----
# Dr. Assistant / SOAP drafts (optional if you only use voice demo without AI clinician notes)
OPENAI_API_KEY=sk-...
# Optional: chat/SOAP model overrides
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_SOAP_MODEL=gpt-4o

# Voice consult: ONE Groq key for STT + LLM + TTS. Default TTS model is Orpheus (playai-tts was retired Dec 2025).
GROQ_API_KEY=gsk_...
# Optional Groq TTS (defaults: canopylabs/orpheus-v1-english, voice troy, wav). Accept Orpheus terms in Groq Console once.
# GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
# GROQ_TTS_VOICE=troy
# GROQ_TTS_RESPONSE_FORMAT=wav

# ---- Database ----
DATABASE_URL=postgresql://telehealth:telehealth_secret@localhost:5433/telehealth_db

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production

# ---- Frontend ----
# API is on 8001 by default (Docker) so another app can use 8000 locally.
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXTAUTH_SECRET=change_this_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ---- Mocked services (no real keys needed for MVP) ----
RAZORPAY_KEY_ID=mock
RAZORPAY_KEY_SECRET=mock
SMS_PROVIDER_KEY=mock
WHATSAPP_PROVIDER_KEY=mock

# ---- App settings ----
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
PDF_STORAGE_PATH=./pdfs
